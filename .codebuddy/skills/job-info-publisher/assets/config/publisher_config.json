{
  "page": {
    "title": "实习岗位推荐",
    "subtitle": "中央音乐学院 · 2028届 · 音乐艺术管理"
  },
  "data": {
    "retention_days": 7,
    "source_format": "csv",
    "default_file": "job_results.csv"
  },
  "features": {
    "enable_search": true,
    "enable_filters": true,
    "enable_sorting": true,
    "enable_new_alerts": true,
    "enable_expired_management": true,
    "enable_password_protection": false
  },
  "password": {
    "enabled": false,
    "default_password": "123456",
    "allow_change": true,
    "storage": "localStorage"
  },
  "ui": {
    "theme": "modern",
    "primary_color": "#667eea",
    "secondary_color": "#764ba2",
    "card_radius": "12px",
    "card_shadow": "0 2px 8px rgba(0,0,0,0.1)"
  },
  "priority_badges": {
    "P0": {
      "color": "#f44336",
      "background": "#ffebee",
      "icon": "🔥"
    },
    "P1": {
      "color": "#ff9800",
      "background": "#fff3e0",
      "icon": ""
    },
    "P2": {
      "color": "#ffc107",
      "background": "#fffde7",
      "icon": ""
    },
    "P3": {
      "color": "#9e9e9e",
      "background": "#f5f5f5",
      "icon": ""
    }
  },
  "time_groups": {
    "today": {
      "label": "今日新增",
      "show_badge": true,
      "badge_color": "#f44336"
    },
    "yesterday": {
      "label": "昨日更新",
      "show_badge": false
    },
    "week": {
      "label": "本周",
      "show_badge": false
    },
    "earlier": {
      "label": "更早",
      "show_badge": false
    },
    "expired": {
      "label": "已过期",
      "show_badge": false,
      "opacity": 0.6
    }
  }
}
